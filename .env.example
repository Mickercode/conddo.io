# Conddo.io frontend environment
# Copy to .env.local and fill in for your environment.

# Base URL of the Conddo backend (Spring Boot). The API client appends /api/v1.
# Leave empty to run the dashboard with empty states (no backend wired yet).
# Local backend default:
NEXT_PUBLIC_API_URL=http://localhost:8080

# Public app URL (used for share/booking links, absolute URLs).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Payments service (separate web service — backend/ACTION_LIST.md §7a).
# The FE talks to this for /payments/init + /payments/{ref}/verify
# (RoutePay checkout). Reads (summary/transactions/outstanding) stay on
# NEXT_PUBLIC_API_URL. Blank → Pay buttons show "Payments are being set up".
# Local dev: http://localhost:8082    Production: your conddo-payments URL.
NEXT_PUBLIC_PAYMENTS_API_URL=

# Google Sign-in (OAuth2 — backend spec at backend/ACTION_LIST.md §1a).
# OAuth client ID from Google Cloud Console → APIs & Services → Credentials.
# Add http://localhost:3000 and your production origin to that client's
# "Authorized JavaScript origins" — no redirect URI needed (popup flow).
# Leave blank to hide the "Continue with Google" buttons.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
