# Conddo.io frontend environment
# Copy to .env.local and fill in for your environment.

# Base URL of the Conddo backend (Spring Boot). The API client appends /api/v1.
# Leave empty to run the dashboard with empty states (no backend wired yet).
# Local backend default:
NEXT_PUBLIC_API_URL=http://localhost:8080

# Public app URL (used for share/booking links, absolute URLs).
NEXT_PUBLIC_APP_URL=http://localhost:3000
